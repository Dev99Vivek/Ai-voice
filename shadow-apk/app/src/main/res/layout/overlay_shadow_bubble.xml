<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <!-- Transcript panel — shown above the bubble -->
    <LinearLayout
        android:id="@+id/ll_transcript_panel"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="72dp"
        android:background="@drawable/bg_overlay_panel"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="monospace"
            android:textColor="#E8F4F8"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Main bubble -->
    <FrameLayout
        android:id="@+id/view_bubble"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/bg_overlay_bubble"
        android:elevation="12dp">

        <!-- State indicator dot -->
        <View
            android:id="@+id/view_state_indicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="@drawable/bg_state_dot" />

        <!-- S letter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:text="S"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold" />
    </FrameLayout>

</FrameLayout>
